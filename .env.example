# ============================================================================  
# MINARET APP - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# 
# SECURITY NOTICE:
# - Never commit actual API keys to version control
# - Copy this file to .env and fill in your actual values
# - Add .env to your .gitignore file
# - Restrict API keys in Google Cloud Console to your app's package name + SHA-1
#
# ============================================================================

# Anthropic API (Optional - for AI features)
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# Google Maps Configuration (Required for location features)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase Configuration (Required)
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_APP_ID=your-firebase-app-id-here
FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id-here
FIREBASE_PROJECT_ID=your-firebase-project-id-here
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain-here
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket-here
FIREBASE_MEASUREMENT_ID=your-firebase-measurement-id-here

# Firebase Android (Required for Android builds)
FIREBASE_ANDROID_API_KEY=your-firebase-android-api-key-here
FIREBASE_ANDROID_APP_ID=your-firebase-android-app-id-here

# Firebase iOS (Required for iOS builds)
FIREBASE_IOS_API_KEY=your-firebase-ios-api-key-here
FIREBASE_IOS_APP_ID=your-firebase-ios-app-id-here
FIREBASE_IOS_BUNDLE_ID=com.atelier.minaretApp

# ============================================================================  
# SECURITY INSTRUCTIONS
# ============================================================================
#
# 1. Google Cloud Console Restrictions:
#    - Go to: https://console.cloud.google.com/
#    - Navigate to APIs & Services > Credentials
#    - Edit each API key and add restrictions:
#      * Application restrictions: Android apps + iOS apps
#      * Package name: com.atelier.minaret
#      * SHA-1 certificate fingerprint from your release keystore
#
# 2. Firebase Security Rules:
#    - Enable App Check in Firebase Console
#    - Configure Firestore security rules
#    - Set up proper authentication requirements
#
# 3. Build Security:
#    - Use: flutter build apk --obfuscate --split-debug-info=build/debug-info/
#    - This obfuscates your code and makes reverse engineering harder
#
# ============================================================================
